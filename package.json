{
  "name": "milodikfx",
  "version": "0.9.0-electron",
  "description": "MilodikFX - Modern audio DSP editor (Electron + React)",
  "author": "MilodikFX Contributors",
  "license": "MIT",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run react-dev\" \"wait-on http://localhost:3000 && npm run electron-dev\"",
    "react-dev": "cd frontend && npm run dev",
    "electron-dev": "electron .",
    "react-build": "cd frontend && npm run build",
    "build": "npm run react-build && npm run build-native",
    "build-native": "node-gyp configure && node-gyp build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "npm run postinstall-frontend",
    "postinstall-frontend": "cd frontend && npm install"
  },
  "dependencies": {
    "electron-is-dev": "^1.0.1",
    "electron-squirrel-startup": "^1.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^27.2.0",
    "electron-builder": "^24.9.1",
    "node-gyp": "^9.4.0",
    "wait-on": "^7.1.0"
  },
  "build": {
    "appId": "com.milodikfx.app",
    "productName": "MilodikFX",
    "directories": {
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "frontend/build/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MilodikFX"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
